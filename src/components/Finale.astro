---
import '../styles/steps.css';
import Capture from './Capture.astro';
---

<section class="step finale" data-screen-label="CTA final">
  <div class="fin">
    <span class="ymark">yendi<i>.</i></span>
    <span class="step-k">Próximamente</span>
    <h2>Di que vas — <em>ya estás yendo.</em></h2>
    <p>Déjanos tu correo y sé de los primeros en probar Yendi.</p>
    <Capture />
  </div>
</section>

<style>
  /* ---- finale-specific overrides of the shared .step/.step-k shell ---- */
  .finale {
    flex-direction: column;
    text-align: center;
  }

  .step.finale {
    min-height: 100svh;
    scroll-snap-align: start;
  }

  .finale .step-k {
    justify-content: center;
  }

  .finale .step-k::before,
  .finale .step-k::after {
    content: "";
    width: 30px;
    height: 1px;
    background: var(--lux-faint);
  }

  /* ---- brand mark ---- */
  .ymark {
    font-family: "Clash Display", "Hanken Grotesk", system-ui, sans-serif;
    font-style: italic;
    font-weight: 700;
    font-size: 34px;
    letter-spacing: -0.02em;
    color: #fff;
    line-height: 1;
  }

  .ymark i {
    font-style: inherit;
    color: var(--lux);
  }

  /* ---- final pitch ---- */
  .fin {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    max-width: 480px;
  }

  .fin h2 {
    font-family: "Clash Display", "Hanken Grotesk", system-ui, sans-serif;
    font-weight: 700;
    font-style: italic;
    font-size: clamp(34px, 7vw, 54px);
    letter-spacing: -0.02em;
    line-height: 1.05;
    text-wrap: balance;
    background: linear-gradient(180deg, #ffffff 18%, #ecdfc8 92%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }

  .fin h2 em {
    font-family: "Cormorant", "Clash Display", Georgia, serif;
    font-style: italic;
    font-weight: 600;
    font-size: 1.12em;
    letter-spacing: 0;
    color: var(--lux);
    -webkit-text-fill-color: var(--lux);
    padding-right: 0.06em;
  }

  .fin p {
    font-size: 16px;
    color: var(--ink-soft);
    text-wrap: pretty;
  }

  /* ---- mobile: full-screen, centered panel ---- */
  @media (max-width: 860px) {
    .step.finale {
      scroll-snap-align: start;
      scroll-snap-stop: always;
      justify-content: center;
      align-items: center;
      padding: 0 26px;
    }
  }
</style>
